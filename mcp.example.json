{
  "mcpServers": {
    "memory": {
      "command": "/usr/bin/python3",
      "args": [
        "$HOME/.claude/hooks/memory_server.py"
      ],
      "cwd": "$HOME"
    },
    "analytics": {
      "command": "/usr/bin/python3",
      "args": [
        "$HOME/.claude/hooks/analytics_server.py"
      ],
      "cwd": "$HOME",
      "defer_loading": true
    }
  }
}
