# Torus Framework — Environment Variables
# Copy to .env and fill in your values

# ── API Keys ──
NIM_API_KEY=              # NVIDIA NIM (embeddings: nv-embed-v1)
GROQ_API_KEY=             # Groq (optional: web search summarization)

# ── MCP Server Ports ──
MEMORY_SSE_HOST=127.0.0.1
MEMORY_SSE_PORT=8742
SKILLS_HOST=127.0.0.1
SKILLS_PORT=8743
SEARCH_HOST=127.0.0.1
SEARCH_PORT=8744
WEB_SEARCH_HOST=127.0.0.1
WEB_SEARCH_PORT=8745
ANALYTICS_HOST=127.0.0.1
ANALYTICS_PORT=8746

# ── Session Flags ──
TORUS_BOT_SESSION=        # Set to "1" for headless/bot sessions
